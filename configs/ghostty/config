# Rishi's focused Ghostty profile.
# Built for Codex, long build logs, git-heavy work, and dense agent sessions.

# Appearance: system-aware, translucent, and still tuned for dense agent work.
theme = light:Catppuccin Latte,dark:Catppuccin Mocha

background-opacity = 0.88
background-blur = true
selection-foreground = #f8fafc
selection-background = #5f6f89
search-foreground = #1f2937
search-background = #f0c66a
search-selected-foreground = #f8fafc
search-selected-background = #6f91c7
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
macos-titlebar-style = transparent
macos-window-shadow = true
macos-window-buttons = visible

# Typography: keep your cross-app CommitMono identity, but make it crisper.
font-family = "CommitMono"
font-style = "Regular"
font-style-bold = "Bold"
font-style-italic = "Italic"
font-style-bold-italic = "Bold Italic"
font-size = 15
font-thicken = false
adjust-cell-height = 2%
adjust-cell-width = 0%

# Cursor and interaction.
cursor-style = block
cursor-style-blink = false
cursor-click-to-move = true
mouse-hide-while-typing = true
mouse-reporting = false
copy-on-select = false
link-url = true
link-previews = true

# macOS behavior.
macos-option-as-alt = true
quit-after-last-window-closed = true
confirm-close-surface = true
shell-integration = detect
shell-integration-features = cursor,title,path

# Motion and affordances.
# Ghostty keeps animation config intentionally small; this is the sweet spot.
resize-overlay = after-first
resize-overlay-position = top-right
resize-overlay-duration = 520ms
quick-terminal-animation-duration = 0.22

# Long-running Codex, Xcode, git, and eval sessions.
scrollback-limit = 20000000
unfocused-split-opacity = 0.92

# Keybinds.
keybind = super+shift+,=reload_config
keybind = super+shift+p=toggle_command_palette
keybind = super+grave_accent=toggle_quick_terminal
keybind = super+shift+m=toggle_mouse_reporting
keybind = super+arrow_left=text:\x01
keybind = super+arrow_right=text:\x05
keybind = super+backspace=text:\x15
keybind = super+delete=text:\x0b
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+[=goto_split:previous
keybind = super+]=goto_split:next
keybind = super+alt+shift+arrow_left=resize_split:left,10
keybind = super+alt+shift+arrow_right=resize_split:right,10
keybind = super+alt+shift+arrow_up=resize_split:up,10
keybind = super+alt+shift+arrow_down=resize_split:down,10
keybind = super+k=clear_screen
