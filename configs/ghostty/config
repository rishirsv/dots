# Rishi's focused Ghostty profile.
# Built for Codex, long build logs, git-heavy work, and dense agent sessions.

# Appearance: neutral, sharp, and close to Codex's dark chrome.
background = #181818
foreground = #f4f4f5
cursor-color = #339cff
selection-background = #26384d
selection-foreground = #ffffff

background-opacity = 0.995
background-blur = false
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
macos-titlebar-style = transparent
macos-window-shadow = true
macos-window-buttons = visible

# ANSI palette: restrained base colors with strong status/error contrast.
palette = 0=#1f1f1f
palette = 1=#fa423e
palette = 2=#40c977
palette = 3=#e5b454
palette = 4=#339cff
palette = 5=#ad7bf9
palette = 6=#4ec9b0
palette = 7=#d4d4d4
palette = 8=#6e6e6e
palette = 9=#ff6965
palette = 10=#63d990
palette = 11=#f0c66a
palette = 12=#66b8ff
palette = 13=#c79cff
palette = 14=#6bd7c3
palette = 15=#ffffff

# Typography: keep your cross-app CommitMono identity, but make it crisper.
font-family = "CommitMono"
font-style = "Regular"
font-style-bold = "Bold"
font-style-italic = "Italic"
font-style-bold-italic = "Bold Italic"
font-size = 15
font-thicken = false
adjust-cell-height = 2%
adjust-cell-width = 0%

# Cursor and interaction.
cursor-style = block
cursor-style-blink = false
cursor-click-to-move = true
mouse-hide-while-typing = true
copy-on-select = false
link-url = true
link-previews = true

# macOS behavior.
macos-option-as-alt = true
quit-after-last-window-closed = true
confirm-close-surface = true
shell-integration = detect
shell-integration-features = cursor,title,path

# Motion and affordances.
# Ghostty keeps animation config intentionally small; this is the sweet spot.
resize-overlay = after-first
resize-overlay-position = top-right
resize-overlay-duration = 520ms
quick-terminal-animation-duration = 0.22

# Long-running Codex, Xcode, git, and eval sessions.
scrollback-limit = 20000000
unfocused-split-opacity = 0.92

# Keybinds.
keybind = super+shift+,=reload_config
keybind = super+shift+p=toggle_command_palette
keybind = super+grave_accent=toggle_quick_terminal
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+[=goto_split:previous
keybind = super+]=goto_split:next
keybind = super+ctrl+arrow_left=resize_split:left,10
keybind = super+ctrl+arrow_right=resize_split:right,10
keybind = super+ctrl+arrow_up=resize_split:up,10
keybind = super+ctrl+arrow_down=resize_split:down,10
keybind = super+k=clear_screen
