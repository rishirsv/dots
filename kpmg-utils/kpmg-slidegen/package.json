{
  "name": "kpmg-slidegen",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Template-driven PPTX generator with QA and optional visual postprocess checks.",
  "scripts": {
    "generate": "node generator/index.js --in decks/deckspec-starter-template.deckSpec.json --out outputs/my-run/deck.pptx --qa-out outputs/my-run/qa.json",
    "generate:layouts": "node generator/index.js --in decks/layout-flex-one-per-layout.deckSpec.json --out outputs/layout-flex/deck.pptx --qa-out outputs/layout-flex/qa.json",
    "qa": "npm run -s test:contracts && npm run -s test:contracts:registry && npm run -s smoke && npm run -s test:drift:theme:strict && npm run -s test:drift:grep",
    "test:contracts": "node scripts/test-layout-contracts.mjs",
    "test:contracts:registry": "node scripts/test-slide-registry-policy-contracts.mjs",
    "test:qa:golden": "node scripts/test-qa-golden.mjs",
    "test:validation:failure": "node scripts/test-validation-failure.mjs",
    "skill:sync": "node scripts/sync-skill-bundle.mjs",
    "skill:verify": "node scripts/verify-skill-bundle.mjs",
    "skill:smoke": "node scripts/verify-skill-bundle.mjs",
    "smoke": "node scripts/smoke-generate.mjs",
    "test:postprocess": "node scripts/test-postprocess-flows.mjs",
    "test:strict:overflow-fail-closed": "node scripts/test-strict-overflow-fail-closed.mjs",
    "test:visual:layouts": "node scripts/test-layout-visual-regressions.mjs",
    "test:visual:one-column": "node scripts/test-one-column-visual-regressions.mjs",
    "test:visual:analysis-bridge": "node scripts/test-analysis-bridge-visual-regressions.mjs",
    "test:visual:business-overview": "node scripts/test-business-overview-visual-regressions.mjs",
    "test:visual:callouts-dense": "node scripts/test-callouts-dense-visual-regressions.mjs",
    "test:visual:bullet-nesting": "node scripts/test-bullet-nesting-visual-regressions.mjs",
    "test:visual:theme-missing-layouts": "node scripts/test-theme-missing-layouts-visual-regressions.mjs",
    "test:visual:theme-e2e": "node scripts/test-theme-e2e-visual-regressions.mjs",
    "test:visual:reference-parity": "node scripts/test-reference-slide-parity.mjs",
    "test:visual:all": "npm run -s validate:visual && npm run -s test:visual:layouts && npm run -s test:visual:one-column && npm run -s test:visual:analysis-bridge && npm run -s test:visual:business-overview && npm run -s test:visual:callouts-dense && npm run -s test:visual:bullet-nesting && npm run -s test:visual:theme-missing-layouts && npm run -s test:visual:theme-e2e",
    "test:pagination:one-column-merge": "node scripts/test-pagination-one-column-merge-regression.mjs",
    "test:pagination:contents-sections": "node scripts/test-pagination-contents-sections-regression.mjs",
    "test:pagination:contents-qa": "node scripts/test-contents-pagination-qa-regression.mjs",
    "test:pagination:table-metadata": "node scripts/test-pagination-analysis-narrow-table-metadata-regression.mjs",
    "test:strict:overlap-sizing": "node scripts/test-overlap-sizing-bounds-regression.mjs",
    "test:validation:bullet-nesting": "node scripts/test-bullet-nesting-validation.mjs",
    "test:validation:table-shape": "node scripts/test-validation-table-shape-regression.mjs",
    "test:render-context:refactor": "node scripts/test-render-context-refactor-regression.mjs",
    "test:footnote:margin-override": "node scripts/test-footnote-margin-override-regression.mjs",
    "test:drift:ast": "node scripts/test-style-drift-ast.mjs",
    "test:drift:ast:strict": "node scripts/test-style-drift-ast.mjs --strict",
    "test:drift:theme": "node scripts/test-theme-drift-guard.mjs",
    "test:drift:theme:strict": "node scripts/test-theme-drift-guard.mjs --strict",
    "test:drift:grep": "node scripts/test-builder-style-grep.mjs",
    "test:drift:grep:strict": "node scripts/test-builder-style-grep.mjs --strict",
    "validate:visual": "node scripts/validate-visual.mjs",
    "new:layout": "node scripts/new-layout.mjs",
    "dev:cover": "node scripts/dev/render-cover-sample.mjs",
    "dev:analysis-narrow": "node scripts/dev/render-analysis-narrow-sample.mjs"
  },
  "dependencies": {
    "image-size": "^2.0.2",
    "pptxgenjs": "^4.0.1"
  },
  "devDependencies": {
    "acorn": "^8.15.0"
  }
}
