# Pulse credential template. Do not put live values in this skill directory.
# Copy this file to ~/.config/pulse/provider-credentials.env, or set the same
# names as shell environment variables. Shell values take precedence.

# Optional paid Reddit backfill and TikTok search.
SCRAPECREATORS_API_KEY=<scrapecreators_api_key>

# Optional X providers. AUTH_TOKEN and CT0 are accepted only for the explicit
# PULSE_X_BACKEND=bird route and must be user-supplied; Pulse never extracts
# browser cookies.
XAI_API_KEY=<xai_api_key>
X_BEARER_TOKEN=<x_api_bearer_token_without_bearer_prefix>
AUTH_TOKEN=<x_auth_token>
CT0=<x_csrf_token>
