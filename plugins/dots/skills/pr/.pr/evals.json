{
  "schema_version": 1,
  "skill_name": "pr",
  "target": {
    "type": "skill",
    "ref": "SKILL.md"
  },
  "defaults": {
    "runner": "codex_app_server",
    "repetitions": 1
  },
  "candidates": [
    {
      "candidate": "current",
      "display": "Current skill",
      "source": {
        "kind": "current_worktree",
        "ref": "."
      }
    }
  ],
  "cases": [
    {
      "id": "pr-activation-required",
      "type": "trigger",
      "task": {
        "prompt": "A user asks: \"Create a draft pull request for the current local changes.\" This is a routing drill: do not run commands or inspect files. Answer with the exact local PR flow you would follow and the checks you would perform before publishing."
      },
      "graders": [
        {
          "id": "activation-evidence",
          "kind": "code",
          "metric": "activation",
          "path": "validate.py",
          "uses_transcript": true,
          "required": true,
          "gate": true
        }
      ]
    },
    {
      "id": "visual-pr-images-required",
      "type": "failure",
      "task": {
        "prompt": "You are updating an existing draft PR for a visual/UI change. The PR already has a text-only list of screens in its body. Explain the exact PR-body update you would make before closing out."
      },
      "graders": [
        {
          "id": "image-embed-gate",
          "kind": "code",
          "metric": "visual-pr-evidence",
          "path": "validate.py",
          "required": true,
          "gate": true
        }
      ]
    }
  ]
}
