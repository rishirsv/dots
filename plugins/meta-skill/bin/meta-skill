#!/usr/bin/env sh
set -eu

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
REPO_ROOT=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
CLI_DIR="$REPO_ROOT/cli"
ENTRY="$CLI_DIR/app/main.js"

if [ ! -f "$ENTRY" ]; then
  echo "error: Meta Skill CLI runtime is missing: $ENTRY" >&2
  exit 1
fi

exec node "$ENTRY" "$@"
