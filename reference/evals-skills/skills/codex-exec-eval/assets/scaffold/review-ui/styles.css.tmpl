:root {
  color-scheme: light;
  --bg: #f4f6f8;
  --panel: #ffffff;
  --border: #d5dde5;
  --text: #16202a;
  --muted: #5e6b77;
  --pass: #1f8f5f;
  --fail: #c43d3d;
  --defer: #9c6b16;
  --accent: #0f5ea8;
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  background: var(--bg);
  color: var(--text);
}

.app-shell {
  display: grid;
  grid-template-columns: 320px 1fr;
  min-height: 100vh;
}

.sidebar {
  background: #102230;
  color: #f2f7fb;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.sidebar label {
  display: flex;
  flex-direction: column;
  gap: 6px;
  font-size: 14px;
}

.sidebar select {
  border-radius: 8px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  padding: 10px;
  background: rgba(255, 255, 255, 0.08);
  color: #f2f7fb;
}

.scoreboard {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 12px;
  padding: 12px;
  font-size: 14px;
  line-height: 1.5;
}

.case-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  overflow-y: auto;
}

.case-item {
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: 10px;
  padding: 10px;
  cursor: pointer;
  background: rgba(255, 255, 255, 0.04);
}

.case-item.active {
  border-color: #8bc4ff;
  background: rgba(139, 196, 255, 0.16);
}

.case-item small {
  color: rgba(255, 255, 255, 0.75);
}

.content {
  padding: 24px;
}

.content-header {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
  margin-bottom: 20px;
}

.shortcuts {
  color: var(--muted);
  font-size: 13px;
}

.case-body {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.panel {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 14px;
  padding: 16px;
}

.panel pre {
  white-space: pre-wrap;
  word-break: break-word;
  margin: 0;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 13px;
}

.grading-panel {
  grid-column: span 2;
}

.grade-buttons {
  display: flex;
  gap: 10px;
  margin-bottom: 12px;
}

.grade-buttons button,
.status-row button {
  border: 1px solid var(--border);
  background: #fff;
  border-radius: 10px;
  padding: 10px 14px;
  cursor: pointer;
}

.grade-buttons button.active[data-verdict="pass"] {
  background: rgba(31, 143, 95, 0.14);
  border-color: var(--pass);
  color: var(--pass);
}

.grade-buttons button.active[data-verdict="fail"] {
  background: rgba(196, 61, 61, 0.14);
  border-color: var(--fail);
  color: var(--fail);
}

.grade-buttons button.active[data-verdict="defer"] {
  background: rgba(156, 107, 22, 0.16);
  border-color: var(--defer);
  color: var(--defer);
}

.notes-label {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

textarea {
  width: 100%;
  border-radius: 10px;
  border: 1px solid var(--border);
  padding: 12px;
  font: inherit;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12px;
}

.checks-list {
  margin: 0;
  padding-left: 18px;
  line-height: 1.6;
}

.hidden {
  display: none;
}

@media (max-width: 980px) {
  .app-shell {
    grid-template-columns: 1fr;
  }

  .case-body {
    grid-template-columns: 1fr;
  }

  .grading-panel {
    grid-column: span 1;
  }
}
