#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
from pathlib import Path
import sys

from eval_lib import (
    build_codex_command,
    candidate_entry,
    candidate_skill_root,
    compute_candidate_score,
    deterministic_checks,
    get_case_result,
    holdout_case_ids,
    latest_candidate,
    load_candidate_index,
    load_cases,
    load_config,
    load_labels,
    render_prompt,
    review_batch_ids,
    run_codex_command,
    save_json,
    shell_join,
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run a candidate through the codex exec eval harness.")
    parser.add_argument("--config", default="codex-eval.json", help="Path to codex-eval.json")
    parser.add_argument("--candidate", default="", help="Candidate version to run, e.g. V1")
    parser.add_argument("--split", choices=["all", "train", "holdout", "review-batch"], default="all")
    parser.add_argument("--case-id", action="append", default=[], help="Run only these case IDs")
    parser.add_argument("--limit", type=int, default=0, help="Run only the first N matching cases")
    parser.add_argument("--dry-run", action="store_true", help="Print commands without executing Codex")
    return parser.parse_args()


def write_summary_md(path: Path, payload: dict) -> None:
    lines = [
        f"# Eval Summary for {payload['candidate']}",
        "",
        f"- Task: {payload['task_name']}",
        f"- Candidate: {payload['candidate']}",
        f"- Cases run: {payload['cases_run']}",
        f"- Deterministic passed: {payload['score']['deterministic_passed']}/{payload['score']['deterministic_total']}",
        f"- Review batch labeled: {payload['score']['review_labeled']}/{payload['score']['review_total']}",
        f"- Review batch passed: {payload['score']['review_passed']}",
        f"- Holdout labeled: {payload['score']['holdout_labeled']}/{payload['score']['holdout_total']}",
        f"- Holdout passed: {payload['score']['holdout_passed']}",
        f"- Holdout target: {payload['score']['target_holdout_pass_count']}",
        f"- Holdout gate met: {payload['score']['holdout_gate_met']}",
        "",
        "## Case Results",
        "",
    ]
    for case in payload["cases"]:
        status = "PASS" if case["passed"] else "FAIL"
        lines.append(f"### {case['id']} [{status}]")
        lines.append(f"- Split: {case['split']}")
        lines.append(f"- Prompt file: {case['prompt_file']}")
        lines.append(f"- Last message: {case['last_message_file']}")
        if case["human_label"]:
            lines.append(f"- Human label: {case['human_label']['verdict']}")
            if case["human_label"].get("notes"):
                lines.append(f"- Human notes: {case['human_label']['notes']}")
        for check in case["checks"]:
            check_status = "PASS" if check["passed"] else "FAIL"
            lines.append(f"- {check['name']}: {check_status} - {check['details']}")
        lines.append("")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(lines), encoding="utf-8")


def filter_cases(cases: list[dict], split: str, review_ids: set[str], selected_ids: set[str], limit: int) -> list[dict]:
    filtered = []
    for case in cases:
        if split == "train" and case.get("split", "train") != "train":
            continue
        if split == "holdout" and case.get("split") != "holdout":
            continue
        if split == "review-batch" and case["id"] not in review_ids:
            continue
        if selected_ids and case["id"] not in selected_ids:
            continue
        filtered.append(case)
    if limit:
        filtered = filtered[:limit]
    return filtered


def main() -> int:
    args = parse_args()
    config_path = Path(args.config).resolve()
    project_dir = config_path.parent
    config = load_config(project_dir)
    index = load_candidate_index(project_dir, config)
    candidate = args.candidate or index.get("active_candidate") or config["target_skill"].get("active_candidate") or latest_candidate(index)
    candidate_meta = candidate_entry(index, candidate) or {}
    tracked_files = candidate_meta.get("tracked_files", config["target_skill"].get("tracked_files", []))

    cases = load_cases(project_dir, config)
    review_ids = set(review_batch_ids(cases, config))
    holdout_ids = set(holdout_case_ids(cases, config))
    cases = filter_cases(cases, args.split, review_ids, set(args.case_id), args.limit)

    prompt_template = (project_dir / config["task"]["prompt_template_file"]).read_text(encoding="utf-8")
    labels = {
        (item["candidate"], item["case_id"]): item
        for item in load_labels(project_dir, config).get("labels", [])
    }

    case_summaries = []
    candidate_root = candidate_skill_root(project_dir, config, candidate)
    working_directory = config["codex_exec"].get("working_directory", ".")
    for case in cases:
        case_id = str(case["id"])
        case_dir = project_dir / config["outputs"]["raw_dir"] / candidate / case_id
        case_dir.mkdir(parents=True, exist_ok=True)

        prompt_text = render_prompt(prompt_template, case, candidate, candidate_root, tracked_files)
        prompt_file = case_dir / "assembled-prompt.md"
        prompt_file.write_text(prompt_text, encoding="utf-8")

        last_message_path = case_dir / "last-message.txt"
        stdout_path = case_dir / ("stdout.jsonl" if config["codex_exec"].get("json_output", False) else "stdout.txt")
        stderr_path = case_dir / "stderr.log"

        cmd = build_codex_command(config, project_dir, last_message_path)
        exit_code = run_codex_command(cmd, prompt_text, stdout_path, stderr_path, args.dry_run)
        last_message = last_message_path.read_text(encoding="utf-8") if last_message_path.exists() else ""
        checks = deterministic_checks(case.get("expected", {}), last_message, project_dir, working_directory, exit_code)
        passed = all(check["passed"] for check in checks)
        human_label = labels.get((candidate, case_id))

        result = {
            "id": case_id,
            "candidate": candidate,
            "split": case.get("split", "train"),
            "review_required": case_id in review_ids,
            "holdout_case": case_id in holdout_ids,
            "passed": passed,
            "exit_code": exit_code,
            "command": shell_join(cmd),
            "prompt_file": str(prompt_file.relative_to(project_dir)),
            "last_message_file": str(last_message_path.relative_to(project_dir)),
            "stdout_file": str(stdout_path.relative_to(project_dir)),
            "stderr_file": str(stderr_path.relative_to(project_dir)),
            "checks": checks,
            "human_label": human_label,
        }
        save_json(case_dir / "result.json", result)
        case_summaries.append(result)

    score = compute_candidate_score(project_dir, config, candidate)
    summary = {
        "task_name": config["task"]["name"],
        "candidate": candidate,
        "cases_run": len(case_summaries),
        "review_batch_ids": sorted(review_ids),
        "holdout_ids": sorted(holdout_ids),
        "score": score,
        "cases": case_summaries,
    }
    reports_dir = project_dir / config["outputs"]["reports_dir"]
    save_json(reports_dir / f"{candidate}-summary.json", summary)
    save_json(project_dir / config["outputs"]["summary_json"], summary)
    write_summary_md(reports_dir / f"{candidate}-summary.md", summary)
    write_summary_md(project_dir / config["outputs"]["summary_md"], summary)
    return 0


if __name__ == "__main__":
    sys.exit(main())
