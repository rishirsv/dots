#!/usr/bin/env python3
from __future__ import annotations

import argparse
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer
import json
from pathlib import Path
from urllib.parse import parse_qs, urlparse

from eval_lib import (
    candidate_entry,
    candidate_skill_root,
    compute_candidate_score,
    get_case_result,
    holdout_case_ids,
    latest_candidate,
    load_candidate_index,
    load_cases,
    load_config,
    load_labels,
    review_batch_ids,
    save_labels,
    upsert_label,
)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Serve the local review UI for a codex exec eval project.")
    parser.add_argument("--project-dir", default=".", help="Eval project root")
    parser.add_argument("--port", type=int, default=8765)
    return parser.parse_args()


def build_state(project_dir: Path, candidate: str = "") -> dict:
    config = load_config(project_dir)
    index = load_candidate_index(project_dir, config)
    chosen = candidate or index.get("active_candidate") or config["target_skill"].get("active_candidate") or latest_candidate(index)
    cases = load_cases(project_dir, config)
    review_ids = set(review_batch_ids(cases, config))
    holdout_ids = set(holdout_case_ids(cases, config))
    labels_payload = load_labels(project_dir, config)
    labels = {(item["candidate"], item["case_id"]): item for item in labels_payload.get("labels", [])}

    case_rows = []
    for case in cases:
        result = get_case_result(project_dir, config, chosen, case["id"])
        last_message_path = project_dir / result["last_message_file"] if result.get("last_message_file") else None
        last_message = last_message_path.read_text(encoding="utf-8") if last_message_path and last_message_path.exists() else ""
        case_rows.append(
            {
                "id": case["id"],
                "prompt": case.get("prompt", ""),
                "input_text": case.get("input_text", ""),
                "source_files": case.get("source_files", []),
                "tags": case.get("tags", []),
                "split": case.get("split", "train"),
                "notes": case.get("notes", ""),
                "review_required": case["id"] in review_ids,
                "holdout_case": case["id"] in holdout_ids,
                "result": result,
                "last_message": last_message,
                "label": labels.get((chosen, case["id"])),
            }
        )

    return {
        "config": config,
        "candidate": chosen,
        "candidate_root": candidate_skill_root(project_dir, config, chosen).as_posix(),
        "candidate_tracked_files": (candidate_entry(index, chosen) or {}).get("tracked_files", []),
        "candidates": [candidate["version"] for candidate in index.get("candidates", [])],
        "cases": case_rows,
        "score": compute_candidate_score(project_dir, config, chosen),
    }


class ReviewHandler(SimpleHTTPRequestHandler):
    project_dir: Path

    def do_GET(self) -> None:
        parsed = urlparse(self.path)
        if parsed.path == "/api/state":
            candidate = parse_qs(parsed.query).get("candidate", [""])[0]
            payload = build_state(self.project_dir, candidate)
            body = json.dumps(payload).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return
        return super().do_GET()

    def do_POST(self) -> None:
        if self.path != "/api/label":
            self.send_error(404, "Not found")
            return
        length = int(self.headers.get("Content-Length", "0"))
        body = self.rfile.read(length)
        payload = json.loads(body.decode("utf-8"))
        config = load_config(self.project_dir)
        labels_payload = load_labels(self.project_dir, config)
        labels_payload = upsert_label(
            labels_payload,
            payload["candidate"],
            payload["case_id"],
            payload["verdict"],
            payload.get("notes", ""),
        )
        save_labels(self.project_dir, config, labels_payload)
        response = json.dumps({"ok": True}).encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(response)))
        self.end_headers()
        self.wfile.write(response)


def make_handler(project_dir: Path):
    class BoundHandler(ReviewHandler):
        pass

    BoundHandler.project_dir = project_dir
    return BoundHandler


def main() -> int:
    args = parse_args()
    project_dir = Path(args.project_dir).resolve()
    web_root = project_dir / "review-ui"
    handler = make_handler(project_dir)
    server = ThreadingHTTPServer(("127.0.0.1", args.port), lambda *a, **k: handler(*a, directory=str(web_root), **k))
    print(f"Review UI: http://127.0.0.1:{args.port}")
    server.serve_forever()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
