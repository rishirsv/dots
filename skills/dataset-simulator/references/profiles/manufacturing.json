{
  "profile_version": "2.0",
  "industry": "manufacturing",
  "display_name": "Manufacturing",
  "revenue_model": "product_based",
  "description": "Product-based revenue with inventory management, COGS, bill of materials, and production metrics",

  "identity": {
    "sector": "Industrial",
    "subvertical": "Manufacturing",
    "jurisdiction": "US",
    "currency": "USD"
  },

  "revenue_streams": [
    {
      "name": "Product Sales",
      "model": "product",
      "pct": 0.92,
      "recognition": "at delivery",
      "billing": "invoice net 30",
      "lag": [30, 60],
      "contract_months": null,
      "unit": "order"
    },
    {
      "name": "Freight Revenue",
      "model": "product",
      "pct": 0.03,
      "recognition": "at shipment",
      "billing": "invoice net 30",
      "lag": [30, 45],
      "contract_months": null,
      "unit": "order"
    },
    {
      "name": "Other Revenue",
      "model": "product",
      "pct": 0.05,
      "recognition": "as earned",
      "billing": "monthly",
      "lag": [15, 30],
      "contract_months": null,
      "unit": "customer"
    }
  ],

  "operating_model": {
    "primary_units": ["product", "customer", "order"],
    "asset_intensity": "heavy",
    "inventory_model": "raw_wip_finished",
    "labor_model": "shift_hourly",
    "site_model": "plant_network",
    "customer_model": "enterprise_msa"
  },

  "regulatory_model": {
    "burden": "moderate",
    "regimes": ["OSHA", "EPA", "state_manufacturing"],
    "required_compliance_docs": ["safety_policy", "training_log", "incident_log", "environmental_log", "quality_manual"]
  },

  "document_triggers": {
    "needs_deferred_revenue_schedule": false,
    "needs_mrr_analysis": false,
    "needs_wip_schedule": false,
    "needs_inventory_ledger": true,
    "needs_bom": true,
    "needs_provider_production": false,
    "needs_store_master": false,
    "needs_project_master": false,
    "needs_timesheet_data": false,
    "needs_loan_tape": false,
    "needs_fleet_master": false,
    "needs_credentialing_roster": false,
    "needs_lot_traceability": false,
    "needs_route_economics": false,
    "needs_payer_mix": false,
    "needs_backlog_schedule": false,
    "needs_comp_sales": false
  },

  "red_flag_library": [
    {
      "name": "Customer concentration",
      "description": "Top customer >20% of revenue",
      "detection": "Revenue by customer analysis",
      "severity": "significant"
    },
    {
      "name": "Inventory obsolescence",
      "description": "Slow-moving inventory >15% of total inventory",
      "detection": "Inventory aging and turns by SKU category",
      "severity": "significant"
    },
    {
      "name": "Margin erosion",
      "description": "Gross margin declining while revenue grows (input cost inflation)",
      "detection": "Price vs volume vs mix bridge",
      "severity": "critical"
    },
    {
      "name": "Equipment age",
      "description": "Average equipment age above useful life with deferred maintenance",
      "detection": "Fixed asset register age analysis vs maintenance spend",
      "severity": "manageable"
    },
    {
      "name": "Single-source supplier",
      "description": "Critical raw material from one supplier with no backup",
      "detection": "Supplier concentration by material category",
      "severity": "critical"
    }
  ],

  "narrative_style": {
    "industry_terms": ["BOM", "routing", "OEE", "PPV", "scrap rate", "capacity utilization", "raw materials", "WIP", "finished goods", "lot", "SKU", "lead time", "safety stock", "reorder point", "quality control", "first-pass yield"],
    "banker_terms": ["throughput", "capacity headroom", "sku rationalization", "input cost pass-through", "end-market exposure", "customer diversification"],
    "legal_terms": ["supply agreement", "purchase order terms", "quality agreement", "warranty terms", "product liability", "recall provisions", "tooling ownership"]
  },

  "bounds": {
    "small": {
      "revenue_min": 5000000,
      "revenue_max": 20000000,
      "headcount_min": 25,
      "headcount_max": 100,
      "product_count_min": 10,
      "product_count_max": 100,
      "customer_count_min": 20,
      "customer_count_max": 200
    },
    "mid": {
      "revenue_min": 20000000,
      "revenue_max": 100000000,
      "headcount_min": 80,
      "headcount_max": 400,
      "product_count_min": 50,
      "product_count_max": 500,
      "customer_count_min": 100,
      "customer_count_max": 1000
    },
    "large": {
      "revenue_min": 100000000,
      "revenue_max": 500000000,
      "headcount_min": 300,
      "headcount_max": 1500,
      "product_count_min": 200,
      "product_count_max": 2000,
      "customer_count_min": 500,
      "customer_count_max": 5000
    }
  },

  "financial_model": {
    "working_capital_drivers": {
      "dso": [30, 60],
      "dpo": [30, 45],
      "inventory_days": [45, 120],
      "deferred_revenue_months": [0, 0],
      "retainage_pct": [0, 0]
    },
    "capex_policy": {
      "pct": [0.03, 0.07],
      "threshold": 5000,
      "useful_life": [7, 15]
    },
    "debt_structure": {
      "type": "term_loan",
      "leverage": [1.5, 3.5],
      "interest": [0.05, 0.08]
    }
  },

  "chart_of_accounts": {
    "revenue": [
      {"code": "4000", "name": "Product Sales", "typical_pct": 0.92},
      {"code": "4100", "name": "Freight Revenue", "typical_pct": 0.03},
      {"code": "4200", "name": "Other Revenue", "typical_pct": 0.05}
    ],
    "cogs": [
      {"code": "5000", "name": "Raw Materials", "typical_pct": 0.35},
      {"code": "5100", "name": "Direct Labor", "typical_pct": 0.15},
      {"code": "5200", "name": "Manufacturing Overhead", "typical_pct": 0.10},
      {"code": "5300", "name": "Freight & Shipping", "typical_pct": 0.05}
    ],
    "opex": [
      {"code": "6000", "name": "Sales & Marketing", "typical_pct": 0.08},
      {"code": "6100", "name": "Research & Development", "typical_pct": 0.03},
      {"code": "6200", "name": "General & Administrative", "typical_pct": 0.08},
      {"code": "6300", "name": "Facility Costs", "typical_pct": 0.04}
    ],
    "assets": [
      {"code": "1000", "name": "Cash and Cash Equivalents"},
      {"code": "1100", "name": "Accounts Receivable"},
      {"code": "1200", "name": "Inventory - Raw Materials"},
      {"code": "1210", "name": "Inventory - Work in Process"},
      {"code": "1220", "name": "Inventory - Finished Goods"},
      {"code": "1300", "name": "Prepaid Expenses"},
      {"code": "1400", "name": "Property, Plant & Equipment"},
      {"code": "1500", "name": "Accumulated Depreciation"}
    ],
    "liabilities": [
      {"code": "2000", "name": "Accounts Payable"},
      {"code": "2100", "name": "Accrued Expenses"},
      {"code": "2200", "name": "Accrued Payroll"},
      {"code": "2300", "name": "Equipment Loans"},
      {"code": "2400", "name": "Line of Credit"},
      {"code": "2500", "name": "Long-term Debt"}
    ],
    "equity": [
      {"code": "3000", "name": "Common Stock"},
      {"code": "3100", "name": "Retained Earnings"},
      {"code": "3200", "name": "Shareholder Distributions"}
    ]
  },

  "documents": {
    "operations": [
      "customer_master",
      "product_master",
      "sales_order_register",
      "invoice_register",
      "inventory_ledger",
      "bill_of_materials",
      "production_schedule",
      "supplier_master"
    ],
    "financials": [
      "trial_balance",
      "income_statement",
      "balance_sheet",
      "cash_flow",
      "ar_aging",
      "ap_aging",
      "inventory_valuation",
      "fixed_asset_schedule"
    ]
  },

  "consistency_rules": [
    {
      "id": "cogs_inventory_flow",
      "description": "COGS = Beginning inventory + Purchases - Ending inventory",
      "check": "cogs == beginning_inventory + purchases - ending_inventory"
    },
    {
      "id": "inventory_tie",
      "description": "Inventory ledger totals tie to balance sheet inventory",
      "check": "sum(inventory_ledger.value) == balance_sheet.total_inventory"
    },
    {
      "id": "sales_revenue_tie",
      "description": "Sum of invoice amounts equals P&L product sales",
      "check": "sum(invoice_register.amount) == income_statement.product_sales"
    },
    {
      "id": "bom_cost_tie",
      "description": "BOM costs tie to standard cost in product master",
      "check": "sum(bom.component_costs) == product_master.standard_cost"
    }
  ],

  "seasonality_patterns": {
    "q1": 0.22,
    "q2": 0.26,
    "q3": 0.24,
    "q4": 0.28,
    "notes": "Q4 uptick from holiday inventory builds"
  },

  "kpis": {
    "gross_margin": {"min": 0.25, "max": 0.45, "typical": 0.35},
    "inventory_turns": {"min": 3, "max": 12, "typical": 6},
    "days_sales_outstanding": {"min": 30, "max": 60, "typical": 45},
    "capacity_utilization": {"min": 0.60, "max": 0.90, "typical": 0.75}
  },

  "qoe_adjustments": {
    "common": [
      "Inventory reserve / obsolescence adjustments",
      "Standard cost variance capitalization",
      "Freight capitalization vs. expensing",
      "Warranty reserve true-up"
    ],
    "owner_addbacks": [
      "Owner compensation normalization",
      "Related party supplier markups",
      "Owner-occupied facility rent"
    ]
  },

  "departments": [
    {"name": "Production", "typical_pct": 0.50},
    {"name": "Warehouse & Shipping", "typical_pct": 0.15},
    {"name": "Quality Control", "typical_pct": 0.08},
    {"name": "Engineering", "typical_pct": 0.07},
    {"name": "Sales", "typical_pct": 0.10},
    {"name": "Administration", "typical_pct": 0.10}
  ]
}
