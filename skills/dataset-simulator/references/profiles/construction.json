  "red_flag_library": [
    {
      "name": "WIP fade",
      "description": "Estimated margins at completion declining across projects",
      "detection": "Compare original vs current estimated margin by project",
      "severity": "critical"
    },
    {
      "name": "Overbilling concentration",
      "description": "Billings in excess of costs concentrated in few projects",
      "detection": "Over/under billing by project as pct of backlog",
      "severity": "significant"
    },
    {
      "name": "Backlog quality",
      "description": "Backlog dominated by low-margin or disputed projects",
      "detection": "Backlog by estimated margin and dispute status",
      "severity": "significant"
    },
    {
      "name": "Subcontractor dependence",
      "description": "Single subcontractor >20% of project costs",
      "detection": "Sub spend concentration analysis",
      "severity": "manageable"
    },
    {
      "name": "Change order disputes",
      "description": "Unapproved change orders >10% of contract value",
      "detection": "Change order status and aging report",
      "severity": "critical"
    }
  ],

