  "validation_rules": [
    {
      "id": "wip_asset_calculation",
      "description": "WIP asset = Costs incurred - Billings (when costs > billings)",
      "check": "wip_schedule.costs_in_excess == balance_sheet.wip_asset"
    },
    {
      "id": "wip_liability_calculation",
      "description": "WIP liability = Billings - Costs incurred (when billings > costs)",
      "check": "wip_schedule.billings_in_excess == balance_sheet.wip_liability"
    },
    {
      "id": "project_revenue_tie",
      "description": "Sum of project revenue equals P&L contract revenue",
      "check": "sum(project_revenue) == income_statement.contract_revenue"
    },
    {
      "id": "retention_tie",
      "description": "Retention receivable ties to contract retention terms",
      "check": "retention_schedule.total == balance_sheet.retention_receivable"
    },
    {
      "id": "percent_complete_validation",
      "description": "Revenue recognized = Contract value × % complete",
      "check": "project.revenue_recognized == project.contract_value * project.percent_complete"
    }
  ],

  "seasonality_patterns": {
    "q1": 0.18,
    "q2": 0.28,
    "q3": 0.30,
    "q4": 0.24,
    "notes": "Weather-dependent; Q2-Q3 peak construction season"
