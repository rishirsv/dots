  "red_flag_library": [
    {
      "name": "Provider concentration",
      "description": "Single provider >30% of production",
      "detection": "Provider production as pct of total collections",
      "severity": "critical"
    },
    {
      "name": "Declining hygiene PPH",
      "description": "Hygiene production per hour below $150 or declining",
      "detection": "Monthly hygiene PPH trend",
      "severity": "significant"
    },
    {
      "name": "Insurance AR aging",
      "description": "Insurance AR >90 days exceeding 10% of total AR",
      "detection": "Insurance AR aging bucket analysis",
      "severity": "significant"
    },
    {
      "name": "Patient attrition",
      "description": "Active patient count declining despite new patient growth",
      "detection": "Patient flow: new vs lost vs reactivated",
      "severity": "critical"
    },
    {
      "name": "Below-market collection rate",
      "description": "Net collection rate below 92%",
      "detection": "Gross charges vs net collections trend",
      "severity": "significant"
    }
  ],

