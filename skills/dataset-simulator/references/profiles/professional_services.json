      {"code": "5100", "name": "Subcontractor Costs", "typical_pct": 0.08},
      {"code": "5200", "name": "Direct Project Costs", "typical_pct": 0.02}
    ],
    "opex": [
      {"code": "6000", "name": "Business Development", "typical_pct": 0.05},
      {"code": "6100", "name": "Professional Development", "typical_pct": 0.03},
      {"code": "6200", "name": "General & Administrative", "typical_pct": 0.12},
      {"code": "6300", "name": "Facility Costs", "typical_pct": 0.06},
      {"code": "6400", "name": "Technology & Software", "typical_pct": 0.04}
    ],
    "assets": [
      {"code": "1000", "name": "Cash and Cash Equivalents"},
      {"code": "1100", "name": "Accounts Receivable - Billed"},
      {"code": "1150", "name": "Unbilled Receivables (WIP)"},
      {"code": "1200", "name": "Prepaid Expenses"},
      {"code": "1300", "name": "Furniture & Equipment"},
      {"code": "1400", "name": "Accumulated Depreciation"}
    ],
    "liabilities": [
      {"code": "2000", "name": "Accounts Payable"},
      {"code": "2100", "name": "Accrued Expenses"},
      {"code": "2200", "name": "Accrued Compensation"},
      {"code": "2300", "name": "Deferred Revenue"},
      {"code": "2400", "name": "Line of Credit"}
    ],
    "equity": [
      {"code": "3000", "name": "Partner Capital"},
