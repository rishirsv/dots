  "documents": {
    "operations": [
      "client_master",
      "engagement_register",
      "timesheet_data",
      "wip_schedule",
      "invoice_register",
      "rate_card",
      "utilization_report"
    ],
    "financials": [
      "trial_balance",
      "income_statement",
      "balance_sheet",
      "cash_flow",
      "ar_aging",
      "ap_aging",
      "wip_aging"
    ]
  },

  "consistency_rules": [
    {
      "id": "billable_hours_revenue",
      "description": "Billable hours × effective rate = professional fees revenue",
      "check": "sum(hours * rate) == income_statement.professional_fees"
    },
    {
      "id": "wip_tie",
      "description": "WIP schedule ending balance ties to unbilled receivables",
      "check": "wip_schedule.ending_balance == balance_sheet.unbilled_receivables"
    },
    {
      "id": "utilization_calculation",
      "description": "Utilization = Billable hours / Available hours",
      "check": "utilization == billable_hours / available_hours"
    },
    {
      "id": "realization_rate",
      "description": "Realization = Collected / Standard billing",
      "check": "realization == actual_collected / standard_billing"
    }
  ],

  "seasonality_patterns": {
    "q1": 0.27,
    "q2": 0.26,
    "q3": 0.21,
    "q4": 0.26,
    "notes": "Q3 summer slowdown; Q1/Q4 busy with year-end work"
  },

  "kpis": {
    "gross_margin": {"min": 0.40, "max": 0.60, "typical": 0.50},
    "utilization_rate": {"min": 0.60, "max": 0.85, "typical": 0.72},
    "realization_rate": {"min": 0.85, "max": 1.0, "typical": 0.92},
    "revenue_per_employee": {"min": 150000, "max": 300000, "typical": 200000}
  },

  "qoe_adjustments": {
    "common": [
      "WIP write-offs / bad debt",
      "Partner compensation normalization",
      "Revenue recognition timing (milestone vs. time)",
      "Non-recurring project costs"
    ],
    "owner_addbacks": [
      "Above-market partner compensation",
      "Partner perquisites (auto, travel)",
      "Related party rent"
    ]
  },

  "departments": [
