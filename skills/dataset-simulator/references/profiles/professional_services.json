{
  "profile_version": "2.0",
  "industry": "professional_services",
  "display_name": "Professional Services",
  "revenue_model": "time_based",
  "description": "Time-based revenue with utilization tracking, WIP, billable hours, and engagement management",

  "identity": {
    "sector": "Professional Services",
    "subvertical": "Professional Services",
    "jurisdiction": "US",
    "currency": "USD"
  },

  "revenue_streams": [
    {
      "name": "Professional Fees",
      "model": "time_based",
      "pct": 0.85,
      "recognition": "as services rendered",
      "billing": "invoice net 30",
      "lag": [30, 60],
      "contract_months": null,
      "unit": "engagement"
    },
    {
      "name": "Retainer Revenue",
      "model": "subscription",
      "pct": 0.10,
      "recognition": "over contract term",
      "billing": "monthly recurring",
      "lag": [15, 30],
      "contract_months": 12,
      "unit": "client"
    },
    {
      "name": "Reimbursable Revenue",
      "model": "time_based",
      "pct": 0.05,
      "recognition": "as incurred",
      "billing": "invoice net 30",
      "lag": [30, 45],
      "contract_months": null,
      "unit": "engagement"
    }
  ],

  "operating_model": {
    "primary_units": ["client", "engagement", "professional"],
    "asset_intensity": "light",
    "inventory_model": "none",
    "labor_model": "billable_professional",
    "site_model": "multi_site",
    "customer_model": "enterprise_msa"
  },

  "regulatory_model": {
    "burden": "light",
    "regimes": ["state_professional_license"],
    "required_compliance_docs": ["license_roster", "ethics_policy"]
  },

  "document_triggers": {
    "needs_deferred_revenue_schedule": false,
    "needs_mrr_analysis": false,
    "needs_wip_schedule": true,
    "needs_inventory_ledger": false,
    "needs_bom": false,
    "needs_provider_production": false,
    "needs_store_master": false,
    "needs_project_master": false,
    "needs_timesheet_data": true,
    "needs_loan_tape": false,
    "needs_fleet_master": false,
    "needs_credentialing_roster": false,
    "needs_lot_traceability": false,
    "needs_route_economics": false,
    "needs_payer_mix": false,
    "needs_backlog_schedule": true,
    "needs_comp_sales": false
  },

  "red_flag_library": [
    {
      "name": "Key person dependence",
      "description": "Top 3 professionals generate >40% of revenue",
      "detection": "Revenue by originating/responsible professional",
      "severity": "critical"
    },
    {
      "name": "Declining utilization",
      "description": "Billable utilization dropping below 70%",
      "detection": "Monthly utilization trend by level",
      "severity": "significant"
    },
    {
      "name": "Realization erosion",
      "description": "Billing realization rate declining (write-offs increasing)",
      "detection": "Standard vs actual billing rate analysis",
      "severity": "significant"
    },
    {
      "name": "Client concentration",
      "description": "Top client >15% of fees",
      "detection": "Revenue by client analysis",
      "severity": "significant"
    },
    {
      "name": "WIP aging",
      "description": "Unbilled WIP >60 days growing as pct of revenue",
      "detection": "WIP aging by engagement",
      "severity": "manageable"
    }
  ],

  "narrative_style": {
    "industry_terms": ["utilization", "realization", "billable hours", "leverage ratio", "revenue per professional", "WIP", "engagement", "retainer", "matter", "practice area", "origination", "bill rate", "collection rate", "backlog"],
    "banker_terms": ["revenue per headcount", "utilization-adjusted margin", "practice mix", "client stickiness", "key-person risk", "organic vs lateral growth"],
    "legal_terms": ["engagement letter", "MSA", "statement of work", "professional liability", "non-solicitation", "garden leave", "partnership agreement", "carried interest"]
  },

  "bounds": {
    "small": {
      "revenue_min": 5000000,
      "revenue_max": 20000000,
      "headcount_min": 20,
      "headcount_max": 80,
      "client_count_min": 30,
      "client_count_max": 150
    },
    "mid": {
      "revenue_min": 20000000,
      "revenue_max": 100000000,
      "headcount_min": 70,
      "headcount_max": 350,
      "client_count_min": 100,
      "client_count_max": 500
    },
    "large": {
      "revenue_min": 100000000,
      "revenue_max": 500000000,
      "headcount_min": 300,
      "headcount_max": 1500,
      "client_count_min": 400,
      "client_count_max": 2000
    }
  },

  "financial_model": {
    "working_capital_drivers": {
      "dso": [45, 75],
      "dpo": [20, 35],
      "inventory_days": [0, 0],
      "deferred_revenue_months": [0, 3],
      "retainage_pct": [0, 0]
    },
    "capex_policy": {
      "pct": [0.01, 0.03],
      "threshold": 2500,
      "useful_life": [3, 5]
    },
    "debt_structure": {
      "type": "revolver",
      "leverage": [0, 1.5],
      "interest": [0.05, 0.07]
    }
  },

  "chart_of_accounts": {
    "revenue": [
      {"code": "4000", "name": "Professional Fees", "typical_pct": 0.85},
      {"code": "4100", "name": "Retainer Revenue", "typical_pct": 0.10},
      {"code": "4200", "name": "Reimbursable Expenses", "typical_pct": 0.05}
    ],
    "cogs": [
